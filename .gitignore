# Compiled binary (the e2e fallback path when VIBE_BINARY_PATH is unset)
/vibe-e2e

# Per-platform npm package binaries are staged at build/release time by
# scripts/stage-platform-package.ts (from the Rust release artifact), never
# committed. Keep the bin/ dirs themselves (via .gitkeep) so the package layout
# is visible in the repo.
packages/vibe-*/bin/*
!packages/vibe-*/bin/.gitkeep
# THIRD-PARTY-LICENSES.md is also staged into each platform package at build time
# (the canonical copy lives at the repo root and is checked in).
packages/vibe-*/THIRD-PARTY-LICENSES.md

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
.cursor/
*.swp
*.swo

# Claude
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Local agent state
.agents/
.codex/

# Environment
.env
.env.local
.env.*.local
.vibe.local.toml

# Logs
*.log

# Node.js
node_modules/
package-lock.json

# Build output
dist/
packages/video/out/

# Rust workspace build artifacts
rust/target/

# Nix
/result
.direnv/

# Test coverage
coverage/
