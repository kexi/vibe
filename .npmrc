node-linker=hoisted
public-hoist-pattern[]=*node-pty*
only-built-dependencies[]=node-pty
only-built-dependencies[]=esbuild
only-built-dependencies[]=sharp

# Link the per-platform binary packages (@kexi/vibe-<platform>) from the
# workspace during local installs. @kexi/vibe pins them as EXACT registry
# versions (security D-2: the published shim must resolve a matched binary), not
# the `workspace:` protocol, so without this pnpm 10 would try to fetch the
# (unpublished) versions from the registry, silently drop the optionalDeps, and
# the committed lockfile would not reproduce — breaking CI's frozen-lockfile
# gate. Publishing still uses the exact package.json versions, not these links.
link-workspace-packages=true
