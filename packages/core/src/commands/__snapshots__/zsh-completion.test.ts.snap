// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`generateZshCompletion > matches the snapshot 1`] = `
"#compdef vibe
# vibe zsh completion — generated by \`vibe shell-setup --shell zsh --with-completion\`

_vibe_commands() {
  local -a commands
  commands=(
    'start:Create a new worktree with the given branch'
    'scratch:Create a worktree with an auto-generated scratch/<timestamp> branch'
    'jump:Jump to an existing worktree by branch name'
    'rename:Rename the current worktree'\\''s branch and directory'
    'clean:Remove current worktree and return to main'
    'home:Return to main worktree without removing current'
    'trust:Trust .vibe.toml in current repository'
    'untrust:Remove trust for .vibe.toml in current repository'
    'verify:Verify trust status and hash history'
    'config:Show current settings'
    'upgrade:Check for updates and show upgrade instructions'
    'shell-setup:Print shell wrapper function for eval'
  )
  _describe 'command' commands
}

_vibe_branches() {
  local -a branches
  branches=("\${(@f)$(git for-each-ref --format='%(refname:short)' refs/heads 2>/dev/null)}")
  compadd -a branches
}

_vibe_worktree_branches() {
  local -a branches
  branches=("\${(@f)$(git worktree list --porcelain 2>/dev/null | awk '/^branch refs\\/heads\\//{sub(/^branch refs\\/heads\\//, ""); print}')}")
  compadd -a branches
}

_vibe_start() {
  _arguments \\
    '--reuse[Use existing branch instead of creating a new one]' \\
    '--base=[Base branch/commit for new branch]:base:' \\
    '--track[Set upstream tracking when using --base]' \\
    '--no-hooks[Skip pre-start and post-start hooks]' \\
    '--no-copy[Skip copying files and directories]' \\
    '(-n --dry-run)'{-n,--dry-run}'[Show what would be executed]' \\
    '(-f --force)'{-f,--force}'[Skip confirmation prompts]' \\
    '1: :_vibe_branches'
}

_vibe_scratch() {
  _arguments \\
    '--reuse[Use existing branch instead of creating a new one]' \\
    '--base=[Base branch/commit for new branch]:base:' \\
    '--track[Set upstream tracking when using --base]' \\
    '--no-hooks[Skip pre-start and post-start hooks]' \\
    '--no-copy[Skip copying files and directories]' \\
    '(-n --dry-run)'{-n,--dry-run}'[Show what would be executed]'
}

_vibe_jump() {
  _arguments \\
    '1: :_vibe_worktree_branches'
}

_vibe_rename() {
  _arguments \\
    '(-n --dry-run)'{-n,--dry-run}'[Show what would be executed]'
}

_vibe_clean() {
  _arguments \\
    '(-f --force)'{-f,--force}'[Skip confirmation prompts]' \\
    '--delete-branch[Delete the branch after removing the worktree]' \\
    '--keep-branch[Keep the branch after removing the worktree]'
}

_vibe_home() {
  _arguments
}

_vibe_trust() {
  _arguments
}

_vibe_untrust() {
  _arguments
}

_vibe_verify() {
  _arguments
}

_vibe_config() {
  _arguments
}

_vibe_upgrade() {
  _arguments \\
    '--check[Check for updates without upgrade instructions]'
}

_vibe_shell_setup() {
  _arguments \\
    '--shell=[Specify shell type]:shell:(bash zsh fish nushell powershell)' \\
    '--with-completion[Append shell autocompletion script to shell-setup output]'
}

_vibe() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \\
    '(-h --help)'{-h,--help}'[Show help message]' \\
    '(-v --version)'{-v,--version}'[Show version information]' \\
    '(-V --verbose)'{-V,--verbose}'[Show detailed output]' \\
    '(-q --quiet)'{-q,--quiet}'[Suppress non-essential output]' \\
    '1: :_vibe_commands' \\
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        start) _vibe_start ;;
        scratch) _vibe_scratch ;;
        jump) _vibe_jump ;;
        rename) _vibe_rename ;;
        clean) _vibe_clean ;;
        home) _vibe_home ;;
        trust) _vibe_trust ;;
        untrust) _vibe_untrust ;;
        verify) _vibe_verify ;;
        config) _vibe_config ;;
        upgrade) _vibe_upgrade ;;
        shell-setup) _vibe_shell_setup ;;
      esac
      ;;
  esac
}

if (( \${+functions[compdef]} )); then
  compdef _vibe vibe
fi
"
`;
