// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`generateFishCompletion > matches the snapshot 1`] = `
"# vibe fish completion — generated by \`vibe shell-setup --shell fish --with-completion\`
complete -c vibe -f

# Subcommands
complete -c vibe -n __fish_use_subcommand -a start -d 'Create a new worktree with the given branch'
complete -c vibe -n __fish_use_subcommand -a scratch -d 'Create a worktree with an auto-generated scratch/<timestamp> branch'
complete -c vibe -n __fish_use_subcommand -a jump -d 'Jump to an existing worktree by branch name'
complete -c vibe -n __fish_use_subcommand -a rename -d 'Rename the current worktree\\'s branch and directory'
complete -c vibe -n __fish_use_subcommand -a clean -d 'Remove current worktree and return to main'
complete -c vibe -n __fish_use_subcommand -a home -d 'Return to main worktree without removing current'
complete -c vibe -n __fish_use_subcommand -a trust -d 'Trust .vibe.toml in current repository'
complete -c vibe -n __fish_use_subcommand -a untrust -d 'Remove trust for .vibe.toml in current repository'
complete -c vibe -n __fish_use_subcommand -a verify -d 'Verify trust status and hash history'
complete -c vibe -n __fish_use_subcommand -a config -d 'Show current settings'
complete -c vibe -n __fish_use_subcommand -a upgrade -d 'Check for updates and show upgrade instructions'
complete -c vibe -n __fish_use_subcommand -a shell-setup -d 'Print shell wrapper function for eval'

# Global flags
complete -c vibe -s h -l help -d 'Show help message'
complete -c vibe -s v -l version -d 'Show version information'
complete -c vibe -s V -l verbose -d 'Show detailed output'
complete -c vibe -s q -l quiet -d 'Suppress non-essential output'

# Dynamic positional completion
complete -c vibe -n '__fish_seen_subcommand_from start' -k -a "(git for-each-ref --format='%(refname:short)' refs/heads 2>/dev/null)"
complete -c vibe -n '__fish_seen_subcommand_from jump' -k -a "(git worktree list --porcelain 2>/dev/null | string match -rg '^branch refs/heads/(.+)')"

# start flags
complete -c vibe -n '__fish_seen_subcommand_from start' -l reuse -d 'Use existing branch instead of creating a new one'
complete -c vibe -n '__fish_seen_subcommand_from start' -l base -r -d 'Base branch/commit for new branch'
complete -c vibe -n '__fish_seen_subcommand_from start' -l track -d 'Set upstream tracking when using --base'
complete -c vibe -n '__fish_seen_subcommand_from start' -l no-hooks -d 'Skip pre-start and post-start hooks'
complete -c vibe -n '__fish_seen_subcommand_from start' -l no-copy -d 'Skip copying files and directories'
complete -c vibe -n '__fish_seen_subcommand_from start' -s n -l dry-run -d 'Show what would be executed'
complete -c vibe -n '__fish_seen_subcommand_from start' -s f -l force -d 'Skip confirmation prompts'

# scratch flags
complete -c vibe -n '__fish_seen_subcommand_from scratch' -l reuse -d 'Use existing branch instead of creating a new one'
complete -c vibe -n '__fish_seen_subcommand_from scratch' -l base -r -d 'Base branch/commit for new branch'
complete -c vibe -n '__fish_seen_subcommand_from scratch' -l track -d 'Set upstream tracking when using --base'
complete -c vibe -n '__fish_seen_subcommand_from scratch' -l no-hooks -d 'Skip pre-start and post-start hooks'
complete -c vibe -n '__fish_seen_subcommand_from scratch' -l no-copy -d 'Skip copying files and directories'
complete -c vibe -n '__fish_seen_subcommand_from scratch' -s n -l dry-run -d 'Show what would be executed'

# rename flags
complete -c vibe -n '__fish_seen_subcommand_from rename' -s n -l dry-run -d 'Show what would be executed'

# clean flags
complete -c vibe -n '__fish_seen_subcommand_from clean' -s f -l force -d 'Skip confirmation prompts'
complete -c vibe -n '__fish_seen_subcommand_from clean' -l delete-branch -d 'Delete the branch after removing the worktree'
complete -c vibe -n '__fish_seen_subcommand_from clean' -l keep-branch -d 'Keep the branch after removing the worktree'

# upgrade flags
complete -c vibe -n '__fish_seen_subcommand_from upgrade' -l check -d 'Check for updates without upgrade instructions'

# shell-setup flags
complete -c vibe -n '__fish_seen_subcommand_from shell-setup' -l shell -r -xa 'bash zsh fish nushell powershell' -d 'Specify shell type'
complete -c vibe -n '__fish_seen_subcommand_from shell-setup' -l with-completion -d 'Append fish autocompletion script to shell-setup output (fish only)'
"
`;
